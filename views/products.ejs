<!doctype html>
<html lang="en">
    <head>
        <title>Product Master</title>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />
        <link
            href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css"
            rel="stylesheet"
            integrity="sha384-T3c6CoIi6uLrA9TneNEoa7RxnatzjcDSCmG1MXxSR1GAsXEV/Dwwykc2MPK8M2HN"
            crossorigin="anonymous"
        />
        <style>
            body {
                min-height: 100dvh;
                display: flex;
                flex-direction: column;
                }

            main {
                flex: 1;
                }

            footer {
                background-color: #212529;
                color: #adb5bd;
                padding: 1.2rem 0;
                text-align: center;
                font-size: 0.9rem;
                }

            footer p {
                margin: 0;
                line-height: 1.8;
                }

            footer .footer-name {
                color: #fff;
                font-weight: 600;
                }

            footer .footer-copy {
                color: #6c757d;
                font-size: 0.8rem;
                }

        </style>
    </head>

    <body>
        <header>
            <nav class="navbar navbar-expand-sm p-3 navbar-dark bg-dark">
                <div class="container">
                    <a class="navbar-brand" href="/products">Product Master</a>
                    <button
                        class="navbar-toggler d-lg-none"
                        type="button"
                        data-bs-toggle="collapse"
                        data-bs-target="#collapsibleNavId"
                        aria-controls="collapsibleNavId"
                        aria-expanded="false"
                        aria-label="Toggle navigation"
                    >
                        <span class="navbar-toggler-icon"></span>
                    </button>
                    <div class="collapse navbar-collapse" id="collapsibleNavId">
                        <ul class="navbar-nav me-auto mt-2 mt-lg-0">
                            <li class="nav-item">
                                <a class="nav-link" href="/categories">Categories</a>
                            </li>
                        </ul>
                    </div>
                </div>
            </nav>
        </header>

        <main>
            
            <div class="container text-right d-flex flex-row-reverse my-3 p-2">
                <div class="card bg-light p-3">
                    <h5>Add New Product</h5>
                    <form action="/products/addP" method="POST">
                        <div class="d-flex gap-2 align-items-center flex-wrap">
                            <input
                                class="rounded form-control"
                                type="text"
                                name="p_name"
                                placeholder="Product Name"
                                required
                                style="width: 180px;"
                            />
                            <select name="c_id" class="form-select rounded" required style="width: 160px;">
                                <option value="" disabled selected>Select Category</option>
                                <% categ.forEach(c => { %>
                                    <option value="<%= c.c_id %>"><%= c.c_name %></option>
                                <% }) %>
                            </select>
                            <button type="submit" class="btn btn-success rounded">Add</button>
                        </div>
                    </form>
                </div>
            </div>

            <div class="container my-3 p-2">
                <div class="table-responsive rounded">
                    <table class="table table-light">
                        <thead class="table-dark">
                            <tr>
                                <th scope="col">Product Id</th>
                                <th scope="col">Product Name</th>
                                <th scope="col">Category Id</th>
                                <th scope="col">Category Name</th>
                                <th scope="col">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (prod.length === 0) { %>
                                <tr>
                                    <td colspan="5" class="text-center text-muted py-4">No products found.</td>
                                </tr>
                            <% } %>
                            <% prod.forEach(p => { %>
                                <tr>
                                    <td><h5><%= p.p_id %></h5></td>
                                    <td><h5><%= p.p_name %></h5></td>
                                    <td><h5><%= p.c_id %></h5></td>
                                    <td><h5><%= p.c_name %></h5></td>
                                    <td class="d-flex gap-1">
                                        <a
                                            class="btn btn-outline-warning"
                                            href="/products/editForm/<%= p.p_id %>"
                                            role="button"
                                        >Edit</a>
                                        &nbsp;
                                        <form
                                            action="/products/deleteP/<%= p.p_id %>"
                                            method="POST"
                                            onsubmit="return confirm('Are You Sure You want to delete?')"
                                        >
                                            <button type="submit" class="btn btn-outline-danger">Delete</button>
                                        </form>
                                    </td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>

                
                <% if (totalP > 1) { %>
                <nav aria-label="Product pagination" class="mt-3">
                    <ul class="pagination justify-content-center">

                        
                        <li class="page-item <%= currentPage === 1 ? 'disabled' : '' %>">
                            <a class="page-link" href="/products?page=<%= currentPage - 1 %>">Previous</a>
                        </li>

                        
                        <% for (let i = 1; i <= totalP; i++) { %>
                            <li class="page-item <%= i === currentPage ? 'active' : '' %>">
                                <a class="page-link" href="/products?page=<%= i %>"><%= i %></a>
                            </li>
                        <% } %>

                        
                        <li class="page-item <%= currentPage === totalP ? 'disabled' : '' %>">
                            <a class="page-link" href="/products?page=<%= currentPage + 1 %>">Next</a>
                        </li>

                    </ul>
                </nav>

                
                <p class="text-center text-muted">
                    Page <%= currentPage %> of <%= totalP %>
                </p>
                <% } %>

            </div>
        </main>

        <%- include('partials/footer') %>

        <script
            src="https://cdn.jsdelivr.net/npm/@popperjs/core@2.11.8/dist/umd/popper.min.js"
            integrity="sha384-I7E8VVD/ismYTF4hNIPjVp/Zjvgyol6VFvRkX/vR+Vc4jQkC+hVqc2pM8ODewa9r"
            crossorigin="anonymous"
        ></script>
        <script
            src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.min.js"
            integrity="sha384-BBtl+eGJRgqQAUMxJ7pMwbEyER4l1g+O15P+16Ep7Q9Q+zqX6gSbd85u4mG4QzX+"
            crossorigin="anonymous"
        ></script>
    </body>
</html>
